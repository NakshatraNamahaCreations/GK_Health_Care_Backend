<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Preventive Maintenance Report — {{report.reportNumber}}</title>
<style>
  *{box-sizing:border-box}
  body{font-family:-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#1f2937;margin:0;font-size:12px}
  .hdr{border-bottom:2px solid #0f766e;padding:16px 24px;display:flex;justify-content:space-between}
  .hdr h1{margin:0;color:#0f766e;font-size:18px}
  .meta{text-align:right;font-size:11px;color:#6b7280}
  .section{padding:14px 24px}
  .section h2{font-size:13px;margin:0 0 8px;color:#0f766e;text-transform:uppercase;letter-spacing:.04em}
  .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:4px 16px}
  .grid .label{color:#6b7280}
  table{width:100%;border-collapse:collapse;margin-bottom:8px}
  th,td{border:1px solid #e5e7eb;padding:6px 8px;text-align:left;vertical-align:top}
  th{background:#f3f4f6;font-weight:600}
  .badge{display:inline-block;padding:1px 6px;border-radius:9999px;font-size:10px;font-weight:600}
  .badge-ok{background:#d1fae5;color:#065f46}
  .badge-issue{background:#fee2e2;color:#991b1b}
  .badge-na{background:#e5e7eb;color:#374151}
  .sig{display:flex;justify-content:space-between;margin-top:24px;padding:0 24px}
  .sig .box{width:45%;border-top:1px solid #9ca3af;padding-top:6px;text-align:center;font-size:11px;color:#374151;min-height:60px}
  .sig img{max-height:60px;display:block;margin:0 auto 4px}
  .footer{padding:18px 24px;font-size:10px;color:#6b7280;border-top:1px solid #e5e7eb;margin-top:18px}
</style>
</head>
<body>
  <div class="hdr">
    <div>
      <h1>{{company.name}}</h1>
      <div style="font-size:11px;color:#6b7280">{{company.address}}</div>
    </div>
    <div class="meta">
      <div><strong>Preventive Maintenance</strong></div>
      <div>{{report.reportNumber}}</div>
      <div>{{formatDate report.reportDate}}</div>
    </div>
  </div>

  <div class="section">
    <h2>Customer & Machine</h2>
    <div class="grid">
      <div><span class="label">Hospital:</span> {{customer.hospitalName}}</div>
      <div><span class="label">Phone:</span> {{customer.phone}}</div>
      <div><span class="label">Machine:</span> {{machine.machineName}} ({{machine.modelNumber}})</div>
      <div><span class="label">Serial #:</span> {{machine.serialNumber}}</div>
      <div><span class="label">Condition:</span> {{report.machineCondition}}</div>
      {{#if report.nextMaintenanceDate}}<div><span class="label">Next PM:</span> {{formatDate report.nextMaintenanceDate}}</div>{{/if}}
    </div>
  </div>

  {{#if report.checklistItems.length}}
  <div class="section">
    <h2>Checklist</h2>
    <table>
      <thead>
        <tr><th style="width:30px">#</th><th>Item</th><th style="width:80px">Status</th><th>Notes</th></tr>
      </thead>
      <tbody>
        {{#each report.checklistItems}}
        <tr>
          <td>{{inc @index}}</td>
          <td>{{this.item}}</td>
          <td>
            <span class="badge {{#if (eq this.status "OK")}}badge-ok{{/if}}{{#if (eq this.status "Issue")}}badge-issue{{/if}}{{#if (eq this.status "NA")}}badge-na{{/if}}">{{this.status}}</span>
          </td>
          <td>{{this.notes}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if report.sparePartsUsed.length}}
  <div class="section">
    <h2>Spare Parts Used</h2>
    <table>
      <thead>
        <tr><th>#</th><th>Code</th><th>Part</th><th>Qty</th><th>Rate</th></tr>
      </thead>
      <tbody>
        {{#each report.sparePartsUsed}}
        <tr>
          <td>{{inc @index}}</td>
          <td>{{this.partCode}}</td>
          <td>{{this.partName}}</td>
          <td>{{this.quantity}}</td>
          <td>{{currency this.rate}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if report.remarks}}
  <div class="section">
    <h2>Remarks</h2>
    <div>{{report.remarks}}</div>
  </div>
  {{/if}}

  <div class="sig">
    <div class="box">
      {{#if report.customerSignatureUrl}}<img src="{{report.customerSignatureUrl}}" />{{/if}}
      Customer Signature
    </div>
    <div class="box">
      {{#if report.technicianSignatureUrl}}<img src="{{report.technicianSignatureUrl}}" />{{/if}}
      Technician — {{technician.name}}
    </div>
  </div>

  <div class="footer">
    Generated on {{formatDate generatedAt "datetime"}} — {{report.reportNumber}}
  </div>
</body>
</html>
