<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{title}}</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      color: #1f2937;
      margin: 0;
      padding: 0;
      font-size: 12px;
    }
    .header {
      border-bottom: 2px solid #0f766e;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header h1 { margin: 0; font-size: 18px; color: #0f766e; }
    .header .meta { text-align: right; font-size: 11px; color: #6b7280; }
    .section { padding: 16px 24px; }
    .section h2 {
      font-size: 13px;
      margin: 0 0 8px;
      color: #0f766e;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
    th, td {
      border: 1px solid #e5e7eb;
      padding: 8px 10px;
      text-align: left;
      vertical-align: top;
    }
    th { background: #f3f4f6; font-weight: 600; }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 4px 16px;
    }
    .grid .label { color: #6b7280; }
    .totals { width: 50%; margin-left: auto; }
    .totals td { border: none; padding: 4px 8px; }
    .totals .grand { font-weight: 700; border-top: 2px solid #0f766e; }
    .footer {
      padding: 24px;
      font-size: 10px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
      margin-top: 24px;
    }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1>{{company.name}}</h1>
      <div style="font-size:11px;color:#6b7280">{{company.address}}</div>
    </div>
    <div class="meta">
      <div><strong>{{documentType}}</strong></div>
      <div>{{documentNumber}}</div>
      <div>{{formatDate documentDate}}</div>
    </div>
  </div>

  <div class="section">
    <h2>Customer</h2>
    <div class="grid">
      <div><span class="label">Name:</span> {{customer.name}}</div>
      <div><span class="label">Phone:</span> {{customer.phone}}</div>
      <div><span class="label">Hospital:</span> {{customer.hospitalName}}</div>
      <div><span class="label">GSTIN:</span> {{customer.gstin}}</div>
      <div style="grid-column: 1 / -1"><span class="label">Address:</span> {{customer.address}}</div>
    </div>
  </div>

  {{#if items}}
  <div class="section">
    <h2>Items</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Description</th>
          <th>Qty</th>
          <th>Rate</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>{{inc @index}}</td>
          <td>{{this.name}}</td>
          <td>{{this.quantity}}</td>
          <td>{{currency this.rate}}</td>
          <td>{{currency this.total}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <table class="totals">
      <tr><td>Sub Total</td><td style="text-align:right">{{currency totals.subTotal}}</td></tr>
      <tr><td>GST</td><td style="text-align:right">{{currency totals.gst}}</td></tr>
      <tr class="grand"><td>Grand Total</td><td style="text-align:right">{{currency totals.grandTotal}}</td></tr>
    </table>
  </div>
  {{/if}}

  {{#if remarks}}
  <div class="section">
    <h2>Remarks</h2>
    <div>{{remarks}}</div>
  </div>
  {{/if}}

  <div class="footer">
    Generated on {{formatDate generatedAt "datetime"}} — This is a system-generated document and does not require a signature.
  </div>
</body>
</html>
