# Server
NODE_ENV=development
PORT=5002
API_PREFIX=/api/v1

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/gk_healthcare

# CORS (comma-separated list, or * for all)
CORS_ORIGIN=*

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info

# Seed (used by `npm run seed`)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_MOBILE=9999999999
SEED_ADMIN_EMAIL=admin@gkhealthcare.local
SEED_ADMIN_PASSWORD=Admin@123

# S3 / S3-compatible storage (Sprint 6+)
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional — only set for non-AWS providers (R2, Spaces, MinIO).
S3_ENDPOINT=
# Optional — public-facing URL prefix (CDN). If unset we fall back to the bucket URL.
S3_PUBLIC_BASE_URL=
# Set true for MinIO / some on-prem S3.
S3_FORCE_PATH_STYLE=false

# Puppeteer (Sprint 6)
# Override the bundled Chromium path if needed (e.g. on minimal Docker images).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
